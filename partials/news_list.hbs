{{!--
  Compact news cards used in the home-page "Latest news" block. Shares the
  .news-card styling with the timeline on /news — only difference is this
  partial is flat (no year groupings) and honours the `news_count` root
  metadata so the home page stays short.
--}}
<ol class="news-cards">
  {{#each collections.news}}
    {{#if (toDisplay)}}
      <li class="news-card">
        <a class="news-card__link" href="/news/{{this.slug}}/">
          <time class="news-card__date" datetime="{{isoDate this.date}}">
            {{getYear this.date}}.{{getMonth this.date}}.{{getDay this.date}}
          </time>
          <div class="news-card__body">
            <h3 class="news-card__title">{{this.title}}</h3>
            <p class="news-card__excerpt">{{excerpt this.body}}</p>
            <p class="news-card__meta">
              {{#if this.author}}{{this.author}}{{/if}}
              {{#if this.readingTime}}
                {{#if this.author}}&nbsp;·&nbsp;{{/if}}
                {{this.readingTime}} min read
              {{/if}}
            </p>
          </div>
        </a>
      </li>
    {{/if}}
  {{/each}}
</ol>
