<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">

  <!--
    Theme bootstrap. Runs synchronously before the stylesheet loads so the
    `data-theme` attribute is already present on <html> when styles first
    paint. Prevents a light-flash on a dark-mode preference, and vice
    versa. Reads a persisted choice from localStorage; falls back to the
    system preference when the user hasn't chosen.
  -->
  <script>
    (function () {
      try {
        var stored = localStorage.getItem("theme");
        var pref = (stored === "light" || stored === "dark") ? stored :
          (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", pref);
      } catch (e) {
        /* private-mode or blocked storage — fall through to media-query default */
      }
    })();
  </script>

  <title>{{#ifEq current_page "home"}}{{site.title_brief}}{{else}}{{title}} — {{site.title}}{{/ifEq}}</title>
  <meta name="description" content="{{site.description}}">
  <meta name="keywords" content="{{site.keywords}}">
  <meta name="author" content="{{site.author}}">

  <meta property="og:title" content="{{#ifEq current_page "home"}}{{site.title_brief}}{{else}}{{title}} — {{site.title}}{{/ifEq}}">
  <meta property="og:site_name" content="{{site.title}}">
  <meta property="og:description" content="{{#if og_description}}{{og_description}}{{else}}{{site.description}}{{/if}}">
  <meta property="og:type" content="{{#if og_type}}{{og_type}}{{else}}website{{/if}}">
  <meta property="og:url" content="{{site.url}}{{#if path}}/{{path}}{{/if}}">
  <meta property="og:image" content="{{site.url}}{{#if og_image}}{{og_image}}{{else}}/res/img/og/sockethub.png{{/if}}">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{#ifEq current_page "home"}}{{site.title_brief}}{{else}}{{title}} — {{site.title}}{{/ifEq}}">
  <meta name="twitter:description" content="{{#if og_description}}{{og_description}}{{else}}{{site.description}}{{/if}}">
  <meta name="twitter:image" content="{{site.url}}{{#if og_image}}{{og_image}}{{else}}/res/img/og/sockethub.png{{/if}}">

  <link rel="canonical" href="{{site.url}}{{#if path}}/{{path}}{{/if}}">
  <link rel="icon" href="/favicon.ico">
  <link rel="stylesheet" href="/res/css/main.css">
  <link rel="alternate" type="application/rss+xml" title="Sockethub News" href="/feed.xml">

  <!-- Matomo -->
  <script>
    var _paq = window._paq = window._paq || [];
    _paq.push(['trackPageView']);
    _paq.push(['enableLinkTracking']);
    (function() {
      var u = "//matomo.silverbucket.net/";
      _paq.push(['setTrackerUrl', u + 'matomo.php']);
      _paq.push(['setSiteId', '4']);
      var d = document,
          g = d.createElement('script'),
          s = d.getElementsByTagName('script')[0];
      g.type = 'text/javascript';
      g.async = true;
      g.src = u + 'matomo.js';
      s.parentNode.insertBefore(g, s);
    })();
  </script>
</head>
<body>
{{>alpha_banner}}
<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href="/">
      <img src="/res/img/sockethub-icon.svg" alt="" width="28" height="28">
      <span class="site-header__brand-text">Sockethub</span>
    </a>
    {{>primary_nav}}
  </div>
</header>
<main id="main">
