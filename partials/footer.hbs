<script>
  (function () {
    var root = document.documentElement;
    var buttons = document.querySelectorAll(".theme-switch__btn");
    var media = matchMedia("(prefers-color-scheme: dark)");

    // What did the user actually pick? "system" when they haven't stored
    // anything; "light" / "dark" when they've chosen explicitly.
    function storedChoice() {
      try {
        var s = localStorage.getItem("theme");
        return (s === "light" || s === "dark") ? s : "system";
      } catch (e) { return "system"; }
    }

    // Resolve a choice to the concrete theme that should be applied to <html>.
    function resolve(choice) {
      if (choice === "light" || choice === "dark") return choice;
      return media.matches ? "dark" : "light";
    }

    // Apply + highlight. Choice is what the user picked; resolved is what
    // the page actually renders as.
    function paint(choice) {
      var resolved = resolve(choice);
      root.setAttribute("data-theme", resolved);
      buttons.forEach(function (b) {
        var on = b.getAttribute("data-theme-set") === choice;
        b.setAttribute("aria-pressed", on ? "true" : "false");
      });
    }

    buttons.forEach(function (b) {
      b.addEventListener("click", function () {
        var choice = b.getAttribute("data-theme-set");
        try {
          if (choice === "system") localStorage.removeItem("theme");
          else                     localStorage.setItem("theme", choice);
        } catch (e) { /* storage blocked — we still paint for this session */ }
        paint(choice);
      });
    });

    // When the user is on "system", react to OS scheme changes live.
    media.addEventListener("change", function () {
      if (storedChoice() === "system") paint("system");
    });

    paint(storedChoice());
  })();
</script>
