{{#ifChannel "alpha"}}
<div class="alpha-banner" data-banner="alpha-{{site.release.version}}" role="region" aria-label="Release channel notice">
  <div class="alpha-banner__inner">
    <span class="alpha-banner__tag">Alpha</span>
    <p class="alpha-banner__text">
      Sockethub <strong>{{site.release.version}}</strong> is the current active-use release.
      <a href="{{site.release.releasesUrl}}" target="_blank" rel="noopener">See the changelog</a>.
    </p>
    <button type="button" class="alpha-banner__close" aria-label="Dismiss release notice">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
</div>
<script>
  (function () {
    var el = document.querySelector('.alpha-banner');
    if (!el) return;
    var key = 'sh-banner-dismissed-' + el.getAttribute('data-banner');
    try {
      if (localStorage.getItem(key) === '1') { el.hidden = true; return; }
    } catch (e) { /* storage disabled; render the banner */ }
    var btn = el.querySelector('.alpha-banner__close');
    if (btn) {
      btn.addEventListener('click', function () {
        el.hidden = true;
        try { localStorage.setItem(key, '1'); } catch (e) { /* ignore */ }
      });
    }
  })();
</script>
{{/ifChannel}}
