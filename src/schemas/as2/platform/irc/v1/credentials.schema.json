{
  "required": [
    "object"
  ],
  "properties": {
    "actor": {
      "type": "object",
      "required": [
        "id"
      ]
    },
    "object": {
      "type": "object",
      "required": [
        "type",
        "nick",
        "server"
      ],
      "additionalProperties": false,
      "not": {
        "required": [
          "password",
          "token"
        ]
      },
      "allOf": [
        {
          "anyOf": [
            {
              "not": {
                "properties": {
                  "saslMechanism": {
                    "const": "PLAIN"
                  }
                },
                "required": [
                  "saslMechanism"
                ]
              }
            },
            {
              "required": [
                "password"
              ]
            },
            {
              "required": [
                "token"
              ]
            }
          ]
        },
        {
          "anyOf": [
            {
              "not": {
                "properties": {
                  "saslMechanism": {
                    "const": "OAUTHBEARER"
                  }
                },
                "required": [
                  "saslMechanism"
                ]
              }
            },
            {
              "required": [
                "token"
              ]
            }
          ]
        }
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "nick": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string",
          "minLength": 1
        },
        "token": {
          "type": "string",
          "minLength": 1
        },
        "server": {
          "type": "string"
        },
        "port": {
          "type": "number"
        },
        "secure": {
          "type": "boolean"
        },
        "sasl": {
          "type": "boolean"
        },
        "saslMechanism": {
          "type": "string",
          "enum": [
            "PLAIN",
            "OAUTHBEARER"
          ]
        },
        "allowInvalidCert": {
          "type": "boolean"
        }
      }
    }
  }
}