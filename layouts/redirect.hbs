<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Moved → {{redirect_to}}</title>
  <meta http-equiv="refresh" content="0; url={{redirect_to}}">
  <link rel="canonical" href="{{redirect_to}}">
  <meta name="robots" content="noindex,follow">
  <script>location.replace("{{redirect_to}}");</script>
  <style>
    body {
      font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
      max-width: 32rem;
      margin: 10vh auto;
      padding: 0 1rem;
      color: #1a100a;
      background: #faf6ef;
      line-height: 1.6;
    }
    a { color: #de0f3c; }
  </style>
</head>
<body>
  <h1>Page moved</h1>
  <p>This page is now at <a href="{{redirect_to}}">{{redirect_to}}</a>.</p>
  <p>Redirecting you automatically…</p>
</body>
</html>
